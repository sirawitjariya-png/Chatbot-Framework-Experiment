# --- Gemini (OpenAI-compatible endpoint) — generates answers, both frameworks ---
GEMINI_API_KEY=your-api-key-here
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# --- Models (shared by BOTH frameworks — see shared/config.py) ---
ROUTER_MODEL=gemini-3.1-flash-lite
ANSWER_MODEL=gemini-3.1-flash-lite

# --- OpenAI (RAGAS judge only — a different model family than the answer
#     model on purpose, to avoid self-preference bias) ---
OPENAI_API_KEY=your-openai-api-key-here
JUDGE_MODEL=gpt-5-mini
JUDGE_EMBED_MODEL=text-embedding-3-small

# --- Decoding ---
EXPERIMENT_TEMPERATURE=0
LLM_TIMEOUT_S=60

# --- Pricing (THB per 1M tokens) — check current Gemini billing before a real run ---
PRICE_INPUT_THB_PER_1M=3.5
PRICE_OUTPUT_THB_PER_1M=14.0
PRICE_CACHED_INPUT_THB_PER_1M=0.875

# --- Experiment parameters ---
N_REPEATS_PER_QUESTION=5
N_RAGAS_REPEATS=5
RANDOM_SEED=42
